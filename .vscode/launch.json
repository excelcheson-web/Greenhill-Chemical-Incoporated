{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Generate SDS PDFs",
      "type": "node",
      "request": "launch",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "args": [
        "${workspaceFolder}/scripts/generate-sds-pdfs.ts"
      ],
      "internalConsoleOptions": "openOnSessionStart",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}